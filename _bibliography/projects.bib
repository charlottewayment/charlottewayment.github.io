@misc{phase1_heat,
  title        = {Characterising Control Roles in Multimodal Biosignals},
  author       = {Wayment, Charlotte},
  year         = {2026},
  note         = {Ongoing · AIMS CDT, Oxford Robotics Institute},
  abstract     = {Most multimodal biosignal control systems are evaluated against a single question: how accurate is the ensemble overall? This project asks a different one — when does each signal actually help, and when does it introduce noise? Rather than optimising for aggregate accuracy, this work characterises the control-relevant properties of EMG, EEG, IMU and gaze signals to understand when each source provides useful input and when it should be down-weighted or overridden — providing an empirically grounded framework for principled fusion strategy selection.},
  website      = {/projects/phase1_HEAT},
  keywords     = {ongoing}
}

@misc{phase2_pnpl,
  title        = {Uncertainty-Aware Allocation of Multimodal Biosignals for Robust Control},
  author       = {Wayment, Charlotte},
  year         = {2026},
  note         = {Ongoing · Neural Processing Lab, University of Oxford},
  abstract     = {Builds on the Phase 1 fusion framework by introducing an uncertainty-aware control layer that adapts in real time to signal degradation — without defaulting to a binary halt. Inspired by the GUARDIAN framework, this work focuses on adaptive modality allocation: deciding when to trust, down-weight, or override a signal to maintain stable control, with the goal of building assistive technology that extends a person's physical capacity and independence while keeping the user in the control loop.},
  website      = {/projects/phase2_PNPL},
  keywords     = {ongoing}
}

@misc{gat_lstm,
  title        = {Groundwater Forecasting in Sparse Sensor Networks},
  author       = {Wayment, Charlotte},
  year         = {2025},
  note         = {MSc Thesis · Durham University},
  abstract     = {A hybrid GAT-LSTM architecture for predicting groundwater levels at entirely ungauged locations using spatial and temporal context from surrounding sites. Tested using a rigorous leave-one-station-out protocol across 14 monitoring stations in the Eden and Esk catchment, achieving a median KGE of 0.676. Performance stratification by bedrock flow type exposed a clear physical account of when and why the model fails — the kind of characterisation more useful for responsible deployment than aggregate benchmark scores.},
  website      = {/projects/msc_gat_lstm},
  keywords     = {academic}
}

@misc{edinburgh_retrofit,
  title        = {Urban-Scale Modelling for a Net-Zero Scotland},
  author       = {Wayment, Charlotte},
  year         = {2024},
  note         = {MA Thesis · University of Edinburgh},
  abstract     = {A data-driven, policy-aligned pipeline to classify Edinburgh's domestic building stock into retrofit typologies using feature-based intersection clustering — a novel approach that separates inherent structural characteristics from modifiable energy performance features. The 12 resulting typologies were mapped spatially across the city and linked directly to existing government funding schemes, with a prototype platform allowing residents to identify their building archetype and access tailored grant eligibility guidance.},
  website      = {/projects/architecture_thesis},
  keywords     = {academic}
}

@misc{hyped,
  title        = {Hyperloop Simulations Engineering},
  author       = {Wayment, Charlotte},
  year         = {2023-24},
  note         = {Academic · University of Edinburgh HYPED Team},
  abstract     = {Multi-scale CFD and solid mechanics simulations using COMSOL Multiphysics to inform structural design decisions and identify high-risk failure points in a working Hyperloop prototype developed for European Hyperloop Week. Simulation-informed iteration reduced manufacturing waste by more than 30% compared to the previous development cycle.},
  website      = {/projects/hyped},
  keywords     = {academic}
}

@misc{wolfwyse,
  title        = {Production Scheduling \& Optimisation Systems},
  author       = {Wayment, Charlotte},
  year         = {2021-2025},
  note         = {Professional · Wolfwyse Ltd.},
  abstract     = {Designed and deployed production-grade scheduling and optimisation systems for multinational manufacturing environments in food and pharmaceutical industries (including MARS and GSK), processing multiple millions of pounds of goods each week. Combined constraint-based methods with evolutionary algorithms to reduce multi-day planning tasks to minutes, integrated into safety- and reliability-critical production APIs with automated feasibility, constraint, and regression checks.},
  website      = {/projects/wolfwyse},
  keywords     = {professional}
}

@misc{hildreth,
  title        = {Facility Modelling for Regulated Manufacturing},
  author       = {Wayment, Charlotte},
  year         = {2018-2020},
  note         = {Professional · J P Hildreth Ltd.},
  abstract     = {Quantitative modelling of spatially and operationally constrained manufacturing systems for clients in highly regulated food and pharmaceutical environments, including GSK and Mars Chocolate. Combined CAD-based spatial modelling with applied optimisation to evaluate layout and workflow trade-offs, communicating technically complex scenario analyses to both engineering and non-technical client teams.},
  website      = {/projects/hildreth},
  keywords     = {professional}
}